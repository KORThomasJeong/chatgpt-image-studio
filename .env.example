# PostgreSQL
POSTGRES_USER=imagestudio
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=imagestudio

# OpenAI
OPENAI_API_KEY=sk-...

# JWT secret — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-strong-secret-at-least-32-chars

# Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key

# Initial admin account (auto-seeded on first run; change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Web port exposed on host
WEB_PORT=8080
